# PrithviNet Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Database URL - Use PostgreSQL for production
# Local: sqlite:///./prithvinet.db
# Production: postgresql://user:password@host:port/dbname
DATABASE_URL=sqlite:///./prithvinet.db

# JWT Secret Key - MUST be changed for production!
# Generate a secure random string: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# AI/Groq API Key (optional - for AI features)
XAI_API_KEY=your-groq-api-key-here

# Environment
ENVIRONMENT=development

# Frontend URL for CORS (production)
FRONTEND_URL=https://your-frontend.vercel.app

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Base URL
# Local: http://localhost:8000
# Production: https://prithvinet-api.onrender.com
VITE_API_URL=https://prithvinet-api.onrender.com
