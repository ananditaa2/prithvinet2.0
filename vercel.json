{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://prithvinet-api.onrender.com/api/$1"
    },
    {
      "src": "/ws/(.*)",
      "dest": "wss://prithvinet-api.onrender.com/ws/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
